---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { SITE_DATA } from '../constants';
import portraitImage from '../assets/portrait.png';

import '../styles/about.css';
---

<Layout pageTitle="About">
    <div class="page-container">
        <h1>About me</h1>

        <div class="about-content">
            <div class="about-intro-wrapper centered-column">
                <div class="about-header centered-column">
                    <Image src={portraitImage} alt={SITE_DATA.name} class="about-portrait" />
                    <h2 class="about-name">{SITE_DATA.name}</h2>
                </div>

                <p class="intro-text">
                    Industrial Engineer with over <strong>20 years of experience</strong> in assembly engineering,
                    industrial plant commissioning, and quality management. Currently serving as
                    <strong>Assembly Director</strong> at TAV Ingenieria S.A., where I lead the coordination
                    and planning of assembly and commissioning of industrial plants and diverse equipment for
                    the <strong>food industry</strong>. My professional background combines technical vision
                    with the ability to lead multidisciplinary teams in international environments.
                </p>
            </div>

            <section>
                <h2>Approach</h2>
                <div class="info-card">
                    <p>
                        "Operational excellence is built on solid processes, clear standards, and a committed team."
                    </p>
                </div>
            </section>

            <section>
                <h2>Specializations</h2>
                <ul class="custom-list">
                    <li>
                        <span class="list-item-title">Industrial Assembly &amp; Commissioning</span>
                        <span class="list-item-description">Planning and execution of assembly and commissioning
                        of complete industrial plants, from detail engineering to final commissioning, ensuring
                        compliance with quality standards and delivery schedules.</span>
                    </li>
                    <li>
                        <span class="list-item-title">Quality Management Systems</span>
                        <span class="list-item-description">Implementation and auditing of systems under
                        ISO 9001 and ISO/TS 16949 standards, including documentation, Statistical Process
                        Control (SPC), and continuous improvement aimed at certification.</span>
                    </li>
                    <li>
                        <span class="list-item-title">International Project Management</span>
                        <span class="list-item-description">Logistics coordination for export of complete
                        plants and equipment, including packing list preparation, cargo logistics, and
                        international transportation to destination ports.</span>
                    </li>
                    <li>
                        <span class="list-item-title">Team Leadership &amp; Operations</span>
                        <span class="list-item-description">Leading multidisciplinary teams in industrial
                        production environments, focused on operational efficiency, procurement management,
                        cost analysis, and production process optimization.</span>
                    </li>
                </ul>
            </section>

            <section>
                <h2>Services Provided</h2>
                <p class="intro-text">
                    Offering extensive experience in industrial plant management and assembly, 
                    with specialized expertise that meets the highest standards in welding procedures. 
                    The primary goal is to deliver exceptional quality while strictly adhering to client timelines.
                </p>
                <ul class="custom-list">
                    <li>
                        <span class="list-item-title">Crane Operations &amp; Heavy Equipment Positioning</span>
                        <span class="list-item-description">Coordination and management of crane operations for
                        positioning large-scale equipment. Plants installed and commissioned worldwide:
                        Argentina (4 milk drying plants), Uruguay (2 milk drying plants), China (1 egg drying plant),
                        Canada (1 egg drying plant), Lithuania (2 egg drying plants), Russia (1 egg drying plant),
                        Ukraine (2 egg drying plants), Mexico (1 egg drying plant).</span>
                    </li>
                    <li>
                        <span class="list-item-title">Sanitary &amp; Food-Grade Piping</span>
                        <span class="list-item-description">Design and installation of piping for food products,
                        CIP wash lines, compressed air, and more. Welding procedures comply with standardized
                        specifications. High expertise in stainless steel (AISI 304 and AISI 316), as well as
                        carbon steel (SAE 1010) for compressed air, steam, and other applications.
                        Our focus extends beyond welding — we emphasize finishing quality and layout design.</span>
                    </li>
                    <li>
                        <span class="list-item-title">Steam Piping Systems</span>
                        <span class="list-item-description">Design and layout of steam piping lines. Construction
                        of manifolds, steam panels, and condensate systems.</span>
                    </li>
                    <li>
                        <span class="list-item-title">Tank &amp; Vessel Construction and Repair</span>
                        <span class="list-item-description">Construction of all types of tanks: with cooling
                        systems, insulated, with or without agitation. Also performs repairs on tanks, troughs,
                        vats, and all types of vessels built in AISI 304 or AISI 316 stainless steel.</span>
                    </li>
                    <li>
                        <span class="list-item-title">Turnkey Project Management</span>
                        <span class="list-item-description">Extensive track record in the execution and management
                        of turnkey plant projects. Responsible for logistics, supply, control, execution, and
                        commissioning.</span>
                    </li>
                    <li>
                        <span class="list-item-title">Electrical &amp; Compressed Air Installations</span>
                        <span class="list-item-description">Design and installation of cable trays, wiring, and
                        connections. Compressed air installations and piping connections.</span>
                    </li>
                </ul>
            </section>
        </div>
    </div>
</Layout>
